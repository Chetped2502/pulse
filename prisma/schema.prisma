generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id Int @id @default(autoincrement())
  tiktokOpenId String @unique
  displayName String
  avatarUrl String
  accessTokenEncrypted String
  refreshTokenEncrypted String
  accessTokenExpiresAt DateTime
  refreshTokenExpiresAt DateTime
  lastSyncedAt DateTime?
  createdAt DateTime @default(now())
  snapshots AccountSnapshot[]
  videos Video[]
}

model AccountSnapshot {
  id Int @id @default(autoincrement())
  accountId Int
  account Account @relation(fields: [accountId], references: [id])
  capturedAt DateTime
  followerCount Int?
  followingCount Int?
  totalLikeCount Int?
  videoCount Int?

  @@unique([accountId, capturedAt])
}

model Video {
  id String @id
  accountId Int
  account Account @relation(fields: [accountId], references: [id])
  description String
  hashtags String
  durationSeconds Int
  coverImageUrl String
  shareUrl String
  embedLink String
  postedAt DateTime
  bookmarkedAt DateTime?
  firstSeenAt DateTime @default(now())
  lastSyncedAt DateTime
  snapshots VideoSnapshot[]
}

model VideoSnapshot {
  id Int @id @default(autoincrement())
  videoId String
  video Video @relation(fields: [videoId], references: [id])
  capturedAt DateTime
  viewCount Int
  likeCount Int
  commentCount Int
  shareCount Int

  @@unique([videoId, capturedAt])
}

model SyncLog {
  id Int @id @default(autoincrement())
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status String
  videosSynced Int @default(0)
  errorMessage String?
}

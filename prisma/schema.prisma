generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id Int @id @default(autoincrement())
  tiktokOpenId String @unique
  displayName String
  avatarUrl String
  accessTokenEncrypted String
  refreshTokenEncrypted String
  accessTokenExpiresAt DateTime
  refreshTokenExpiresAt DateTime
  lastSyncedAt DateTime?
  createdAt DateTime @default(now())
}

model AccountSnapshot {
  id Int @id @default(autoincrement())
  accountId Int
  capturedAt DateTime
  followerCount Int?
  followingCount Int?
  totalLikeCount Int?
  videoCount Int?
}

model Video {
  id String @id
  accountId Int
  description String
  hashtags String
  durationSeconds Int
  coverImageUrl String
  shareUrl String
  embedLink String
  postedAt DateTime
  bookmarkedAt DateTime?
  firstSeenAt DateTime @default(now())
  lastSyncedAt DateTime
}

model VideoSnapshot {
  id Int @id @default(autoincrement())
  videoId String
  capturedAt DateTime
  viewCount Int
  likeCount Int
  commentCount Int
  shareCount Int
}

model SyncLog {
  id Int @id @default(autoincrement())
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status String
  videosSynced Int @default(0)
  errorMessage String?
}